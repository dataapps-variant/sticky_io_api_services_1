# Copy to .env for LOCAL testing only. On Cloud Run, set these as the Job's
# environment variables instead (and use Secret Manager for the credential).

# --- required ---
MODE=backfill                 # backfill | incremental
BQ_PROJECT=variant-finance-data-project
BQ_DATASET=Sticky_ETL
BQ_LOCATION=US                # must match your BigQuery data location (US / EU / europe-west1)
STICKY_COMPANY=pdfdotnet      # which app from config/apps.yaml, or "all"

# --- backfill start (dynamic end is always "today") ---
BACKFILL_START=2025-11-01

# --- credential for LOCAL testing only (on Cloud Run use Secret Manager) ---
# Format: username:password
# STICKY_CRED=myuser:mypassword

# --- optional tuning (safe defaults shown) ---
# RATE_LIMIT_PER_MINUTE=15
# CONCURRENCY=80
# ORDER_VIEW_BATCH_SIZE=500
# BQ_FLUSH_ROWS=5000
# INCREMENTAL_ORIGINAL_OVERLAP_DAYS=1
# INCREMENTAL_UPDATED_LOOKBACK_DAYS=45
# LOG_LEVEL=INFO
